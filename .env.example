# MailSubsystem development environment
# Copy to .env or run `make init`.

# Path to the MailSubsystem core checkout. The default assumes sibling clones:
#   ~/Developer/MailSubsystem
#   ~/Developer/mailsubsystem-dev-env
MAILSUBSYSTEM_CORE_DIR=../MailSubsystem

# Host ports exposed by Docker.
MAILSUBSYSTEM_DB_PORT=15432
SANDBOX_IMAPS_PORT=1993
SANDBOX_IMAP_PORT=1143

# Sandbox IMAP credentials.
SANDBOX_IMAP_USER=testuser
SANDBOX_IMAP_PASS=testpass123
